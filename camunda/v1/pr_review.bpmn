<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1eizcxu" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_1muvqz1" name="PR Review" isExecutable="true">
    <bpmn:sequenceFlow id="Flow_0b9ylrw" sourceRef="StartEvent_1" targetRef="Activity_18u4gxv">
      <bpmn:extensionElements />
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_0w3j48x" name="Get Pulls" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;https://api.github.com/repos/&#34; + owner + &#34;/&#34; + repo + &#34;/pulls&#34;" target="url" />
          <zeebe:input source="={&#10;  Authorization: &#34;Bearer &#34; + githubToken,&#10;  &#34;Accept&#34;: &#34;application/vnd.github+json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultVariable" value="pr_response" />
          <zeebe:header key="resultExpression" value="={&#10;  prs: response.body,&#10;  prOptions: for p in response.body return {&#10;    label: p.title + &#34; (#&#34; + string(p.number) + &#34;)&#34;,&#10;    value: p.number&#10;  }&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1tixpg5</bpmn:incoming>
      <bpmn:outgoing>Flow_0fh1zbk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="StartEvent_1" name="PR notification">
      <bpmn:extensionElements />
      <bpmn:outgoing>Flow_0b9ylrw</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_1nz4dk4" name="Select PR">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="pr" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0fh1zbk</bpmn:incoming>
      <bpmn:outgoing>Flow_1yckaq2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0fh1zbk" sourceRef="Activity_0w3j48x" targetRef="Activity_1nz4dk4" />
    <bpmn:sequenceFlow id="Flow_1yckaq2" sourceRef="Activity_1nz4dk4" targetRef="Activity_15c6isc" />
    <bpmn:userTask id="Activity_18u4gxv" name="Enter info">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="inputs" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0b9ylrw</bpmn:incoming>
      <bpmn:outgoing>Flow_1tixpg5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1tixpg5" sourceRef="Activity_18u4gxv" targetRef="Activity_0w3j48x" />
    <bpmn:userTask id="Activity_15c6isc" name="Decide">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="decision" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1yckaq2</bpmn:incoming>
      <bpmn:outgoing>Flow_0yzenw0</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_0ecbxmm" name="Aprrove/Reject" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="= &#34;https://api.github.com/repos/&#34; + owner + &#34;/&#34; + repo + &#34;/pulls/&#34; + string(PR_ID) + &#34;/reviews&#34;" target="url" />
          <zeebe:input source="={&#10;  Authorization: &#34;Bearer &#34; + githubToken,&#10;  &#34;Accept&#34;: &#34;application/vnd.github+json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="={&#10;  event: if decision = &#34;approve&#34; then &#34;APPROVE&#34;&#10;         else (if decision = &#34;review&#34; then &#34;REQUEST_CHANGES&#34; else &#34;COMMENT&#34;),&#10;  body: comment&#10;}" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  myResponseBody: response.body&#10;  // Use FEEL to extract values, e.g.,:&#10;  // myUserId: response.body.post.userId&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0yzenw0</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0yzenw0" sourceRef="Activity_15c6isc" targetRef="Activity_0ecbxmm" />
  </bpmn:process>
